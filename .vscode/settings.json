{
    "cmake.statusbar.advanced": {
        "debug": {
            "visibility": "hidden"
        },
        "launch": {
            "visibility": "hidden"
        },
        "build": {
            "visibility": "default"
        },
        "buildTarget": {
            "visibility": "hidden"
        }
    },
    "cmake.buildBeforeRun": true,
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    // Dynamic GDB path using environment variable for better portability
    "cortex-debug.gdbPath": "${env:ARM_GDB_PATH}/bin/arm-none-eabi-gdb",
    // Source dir contains CMakeLists.txt + CMakePresets.json. Build dirs
    // are owned by the presets ("binaryDir" in CMakePresets.json), so we
    // don't pin cmake.buildDirectory anymore.
    "cmake.sourceDirectory": "${workspaceFolder}/rp/src",
    "cmake.useCMakePresets": "always",
    "cmake.defaultConfigurePreset": "pico_w-debug",
    "cmake.defaultBuildPreset": "pico_w-debug",
    // Disabling error squiggles to reduce clutter, but consider "enabled" for more feedback
    "C_Cpp.errorSquiggles": "disabled",
    "C_Cpp.codeAnalysis.clangTidy.enabled": true,
    "C_Cpp.codeAnalysis.exclude": {
        "**/fatfs-sdk": true,
        "**/pico-sdk": true,
        "**/pico-extras": true,
        "**/dist": true,
        "**/rp/src/settings": true,
        "**/rp/build-pico_w-debug": true,
        "**/rp/build-pico_w-release": true,
        "**/target": true
    },
    "C_Cpp.clangTidy.args": [],
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "[c]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "C_Cpp.clang_format_style": "file:${workspaceFolder}/.clang-format",
    "C_Cpp.formatting": "clangFormat",
    "editor.formatOnSave": true,
    "C_Cpp.codeAnalysis.clangTidy.useBuildPath": true,
    "C_Cpp.codeAnalysis.clangTidy.path": "/usr/local/opt/llvm/bin/clang-tidy",
    "C_Cpp.codeAnalysis.clangTidy.checks.disabled": [],
    "C_Cpp.codeAnalysis.clangTidy.args": [
        "--extra-arg=-ferror-limit=1"
    ],
    // --- Git extension: stop the index.lock churn ---
    // VSCode auto-refreshes git status on every file change / window
    // focus. During a burst of changes (e.g. a branch checkout, or a tool
    // editing many files) it fires `git status` rapidly and can leave a
    // stale .git/index.lock, which then collides with command-line git
    // ("fatal: Unable to create '.git/index.lock': File exists"). Turning
    // off the automatic refresh + periodic fetch removes that churn; use
    // the Source Control panel's refresh button when you want to update it
    // manually (it still updates after you stage/commit from the UI).
    "git.autorefresh": false,
    "git.autofetch": false,
    // Don't auto-open/scan the bundled SDK submodules as separate repos
    // (more background git processes on a large tree).
    "git.detectSubmodules": false,
    "git.scanRepositories": []
}